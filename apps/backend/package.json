{
  "name": "@sistema-ponto/backend",
  "version": "1.0.0",
  "description": "Backend API para sistema de controle de ponto",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "npx prisma generate && nodemon --exec \"ts-node --transpile-only src/index.ts\"",
    "dev:nodemon": "nodemon --exec \"ts-node --transpile-only src/index.ts\"",
    "build:permission-modules": "cd ../.. && npm run build -w @sistema-ponto/permission-modules",
    "build": "npm run build:permission-modules && npx prisma generate && tsc",
    "start": "node scripts/resolve-migrations.js && npx prisma migrate deploy && node dist/index.js",
    "start:with-build": "npm run build && node scripts/resolve-migrations.js && npx prisma migrate deploy && node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "fluig:get-tokens": "ts-node scripts/get-fluig-tokens.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sistema-ponto/permission-modules": "file:../../packages/permission-modules",
    "@types/bcrypt": "^6.0.0",
    "@types/moment": "^2.11.29",
    "@types/pdfkit": "^0.17.4",
    "aws-sdk": "^2.1509.0",
    "axios": "^1.6.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "date-fns-tz": "^3.2.0",
    "dayjs": "^1.11.18",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.4",
    "oauth-1.0a": "^2.2.6",
    "pdfkit": "^0.17.2",
    "resend": "^3.2.0",
    "uuid": "^9.0.1",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5",
    "yn": "^3.1.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.21",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prisma": "^5.7.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "ponto",
    "frequencia",
    "engenharia",
    "api",
    "nodejs",
    "express"
  ],
  "author": "Sistema Ponto Engenharia",
  "license": "MIT",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
