  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  updater  User?    @relation("UserDpApprovalContractUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@unique([userId, contractId])
  @@index([userId])
  @@index([contractId])
  @@map("user_dp_approval_contracts")
}

/// Template de permissões por cargo (nome do campo `Employee.position`). Usado como padrão na tela Permissões.
model PositionPermissionTemplate {
  id                    String   @id @default(cuid())
  position              String   @unique
  permissions           Json
  allowedContractIds    Json     @default("[]")
  dpApprovalContractIds Json     @default("[]")
  /// Map contractId -> { orcamento, relatorios, ordemServico, producaoSemanal, recebimentoEntregas }
  contractModuleFlags   Json     @default("{}")
  updatedAt             DateTime @updatedAt

  @@map("position_permission_templates")
}

// Drive — pastas e arquivos armazenados no S3
model DriveFolder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  ownerId   String
  createdAt DateTime @default(now())
