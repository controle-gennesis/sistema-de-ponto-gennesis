  @@index([name])
  @@map("espelho_nf_bank_accounts")
}

// Espelho NF — Espelho salvo
model EspelhoNfMirror {
  id                    String    @id @default(cuid())
  measurementRef        String
  costCenterId          String
  dueDate               DateTime?
  municipality          String?
  cnae                  String?
  serviceIssqn          String?
  empenhoNumber         String?
  processNumber         String?
  serviceOrder          String?
  measurementStartDate  String?
  measurementEndDate    String?
  buildingUnit          String?
  /// Nº inscrição Obra / CNO (formato xx.xxx.xxxxx/xx)
  obraCno               String?
  /// Garantia complementar (texto livre)
  garantiaComplementar  String?
  observations          String?
  notes                 String?
  measurementAmount     String
  laborAmount           String
  materialAmount        String
  providerId            String
  takerId               String
  bankAccountId         String
  taxCodeId             String
  nfAttachmentName      String?
  nfAttachmentMimeType  String?
  nfAttachmentSize      Int?
  nfAttachmentDataUrl   String?
  xmlAttachmentName     String?
  xmlAttachmentMimeType String?
  xmlAttachmentSize     Int?
  xmlAttachmentDataUrl  String?
  /// Quais campos opcionais da NF o usuário escolheu exibir/preencher (JSON: processNumber, empenhoNumber, …)
  nfConstarNaNota       Json?
  /// Confirmação obrigatória de que o usuário revisou “constar na nota fiscal”
  nfConstarNaNotaAcknowledged Boolean @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

