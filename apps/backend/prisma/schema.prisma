  stateRegistration     String
  corporateName         String
  tradeName             String
  address               String
  city                  String
  state                 String
  email                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  mirrors EspelhoNfMirror[]

  @@index([corporateName])
  @@index([cnpj])
  @@map("espelho_nf_service_providers")
