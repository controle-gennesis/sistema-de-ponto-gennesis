  bankAccount EspelhoNfBankAccount     @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  taxCode     EspelhoNfTaxCode         @relation(fields: [taxCodeId], references: [id], onDelete: Restrict)

  @@index([costCenterId])
  @@index([providerId])
  @@index([takerId])
  @@index([bankAccountId])
  @@index([taxCodeId])
  @@index([createdAt])
  @@map("espelho_nf_mirrors")
}

// Modelo de Contrato (Engenharia)
model Contract {
  id               String   @id @default(cuid())
  name             String // Nome do contrato
  number           String   @unique // Número do contrato
  startDate        DateTime // Início da vigência
  endDate          DateTime // Fim da vigência
  costCenterId     String // Centro de custo associado
  valuePlusAddenda Decimal  @db.Decimal(15, 2) // Valor mais aditivos
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relacionamentos
  costCenter        CostCenter                 @relation(fields: [costCenterId], references: [id], onDelete: Restrict)
  billings          ContractBilling[]
  annualValues      ContractAnnualValue[]
  addenda           ContractAddendum[]
  pleitos           Pleito[]
  weeklyProductions ContractWeeklyProduction[]
  userPermissions   UserContractPermission[]
  dpApprovalUsers   UserDpApprovalContract[]
  demandSheetApprovals DemandSheetApproval[]
  materialDeliveries   MaterialDelivery[]
  fuelRefuelRequests   FuelRefuelRequest[]
  logisticsDeliveryRequests LogisticsDeliveryRequest[]

  @@index([costCenterId])
  @@index([number])
  @@map("contracts")
}

enum DemandSheetApprovalStatus {
  WAITING_MANAGER
  APPROVED
  REJECTED
  CANCELLED
}

/// Status de compras/suprimentos após aprovação do gestor (um único valor por FD).
enum DemandSheetPurchaseStatus {
  WAREHOUSE_DF
  WAREHOUSE_GO
  FULLY_FULFILLED_BY_STOCK
  PARTIALLY_FULFILLED_BY_STOCK
  PURCHASE_REQUEST
  SUPPLIES
  FINISHED
}

/// Ficha de demanda (FD) — fluxo de aprovação pelo gestor do contrato (mesmo escopo das solicitações DP).
model DemandSheetApproval {
  id                      String                      @id @default(cuid())
  numMovRm                String
  idMovRm                 String
  codigoPedido            String
  solicitanteId           String
  contratoId              String
  obra                    String
  codFichaDemanda         String
  faturamentoEstimado     Decimal                     @db.Decimal(15, 2)
  custoEstimado           Decimal                     @db.Decimal(15, 2)
  observacao              String
  dataHora                DateTime
  polo                    String
  anexos                  Json                        @default("[]")
  status                  DemandSheetApprovalStatus   @default(WAITING_MANAGER)
  createdBy               String
  managerApprovedBy       String?
  managerApprovedAt       DateTime?
  managerApprovalComment  String?
  managerRejectionReason  String?
  managerRejectionComment String?
  purchaseStatus          DemandSheetPurchaseStatus?
  purchaseStatusUpdatedBy String?
  purchaseStatusUpdatedAt DateTime?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  solicitante            User     @relation("DemandSheetApprovalSolicitante", fields: [solicitanteId], references: [id], onDelete: Restrict)
  contrato               Contract @relation(fields: [contratoId], references: [id], onDelete: Restrict)
  creator                User     @relation("DemandSheetApprovalCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  managerApprover        User?    @relation("DemandSheetApprovalManager", fields: [managerApprovedBy], references: [id], onDelete: SetNull)
  purchaseStatusUpdater  User?    @relation("DemandSheetApprovalPurchaseStatusUpdater", fields: [purchaseStatusUpdatedBy], references: [id], onDelete: SetNull)

  @@index([contratoId])
  @@index([solicitanteId])
  @@index([createdBy])
  @@index([status])
  @@index([purchaseStatus])
  @@index([codFichaDemanda])
  @@map("demand_sheet_approvals")
}

// Aditivos do contrato (permite múltiplos lançamentos com data de efeito)
model ContractAddendum {
  id            String   @id @default(cuid())
  contractId    String
  effectiveDate DateTime
  amount        Decimal  @db.Decimal(15, 2) // pode ser positivo ou negativo
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([contractId, effectiveDate])
  @@map("contract_addenda")
}

// Valor anual customizado por ano (permite valor diferente a cada ano)
model ContractAnnualValue {
  id                            String    @id @default(cuid())
  contractId                    String
  year                          Int // Ano (ex: 2025)
  value                         Decimal   @db.Decimal(15, 2) // Valor anual final (base + ajuste), espelho para relatórios
  /// Soma algebrica ao valor anual calculado pelo contrato (orçamento do órgão naquele ano)
  budgetAdjustmentDelta         Decimal?  @db.Decimal(15, 2)
  /// Data do aditivo/orçamento: a partir deste mês civil a meta mensal usa (base + delta) ÷ 12
  budgetAdjustmentEffectiveDate DateTime?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  // Relacionamentos
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, year])
  @@index([contractId])
  @@map("contract_annual_values")
}

// Modelo de Faturamento do Contrato
model ContractBilling {
  id            String   @id @default(cuid())
  contractId    String
  issueDate     DateTime // Data de emissão
  invoiceNumber String // Número da nota fiscal
  serviceOrder  String // Ordem de serviço
  divSe         String? // OS / SE
  grossValue    Decimal  @db.Decimal(15, 2) // Valor bruto
  netValue      Decimal  @db.Decimal(15, 2) // Valor líquido
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relacionamentos
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("contract_billings")
}

// Produção Semanal do contrato
model ContractWeeklyProduction {
  id                    String   @id @default(cuid())
  contractId            String
  fillingDate           DateTime @default(now()) // Data em que o usuário preencheu (não editável)
  divSe                 String // OS / SE
  weeklyProductionValue Decimal  @db.Decimal(15, 2) // Valor da Produção Semanal
  responsiblePerson     String // Responsável pelo Preenchimento
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("contract_weekly_productions")
}

// Andamento da OS — acompanhamento de ordens de serviço (Engenharia); tabela API: pleitos
model Pleito {
  id                 String    @id @default(cuid())
  serviceOrderId     String
  mes                Int
  ano                Int
  valorPrevisto      Decimal   @db.Decimal(14, 2)
  valorExecutado     Decimal   @default(0) @db.Decimal(14, 2)
  dataMedicao        DateTime?
  observacao         String?
  creationMonth      String? // Mês de criação (01-12)
  creationYear       Int? // Ano de criação
  startDate          DateTime? // Data início
  endDate            DateTime? // Data término
  budgetStatus       String? // Status orçamento
  folderNumber       String? // Nº pasta
  lot                String? // Lote
  divSe              String? // Div SE
  location           String? // Local
  unit               String? // Unidade
  serviceDescription String    @db.Text // Descrição do serviço
  budget             String? // Orçamento (referência/texto)
  executionStatus    String? // Status execução
  billingStatus      String? // Status faturamento
  updatedContractId  String? // ID atualizado contrato
  accumulatedBilled  Decimal?  @db.Decimal(15, 2) // Acumulado faturado (moeda)
  billingRequest     Decimal?  @db.Decimal(15, 2) // Pendente faturamento (moeda)
  invoiceNumber      String? // Nº nota
  estimator          String? // Orçamentista
  budgetAmount1      Decimal?  @db.Decimal(15, 2) // Orçamento R$ 1
  budgetAmount2      Decimal?  @db.Decimal(15, 2)
  budgetAmount3      Decimal?  @db.Decimal(15, 2)
  budgetAmount4      Decimal?  @db.Decimal(15, 2)
  pv                 String? // RVI — FEITO ou PENDENTE
  ipi                String? // RVF — FEITO ou PENDENTE
  reportsBilling     String? // Cobrança laudos
  engineer           String? // Engenheiro
  supervisor         String? // Encarregado
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  service_orders  service_orders @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  updatedContract Contract?      @relation(fields: [updatedContractId], references: [id], onDelete: SetNull)

  @@unique([serviceOrderId, mes, ano])
  @@index([ano, mes])
  @@index([folderNumber])
  @@index([serviceOrderId])
  @@index([updatedContractId])
  @@map("pleitos")
}

// Modelo de Obra/Projeto
model Project {
  id           String        @id @default(cuid())
  code         String        @unique // Código da obra
  name         String // Nome da obra
  description  String? // Descrição da obra
  costCenterId String // Centro de custo associado
  status       ProjectStatus @default(ACTIVE) // Status da obra
  startDate    DateTime? // Data de início
  endDate      DateTime? // Data de término prevista
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relacionamentos
  costCenter       CostCenter        @relation(fields: [costCenterId], references: [id], onDelete: Restrict)
  materialRequests MaterialRequest[]

  @@index([code])
  @@index([costCenterId])
  @@index([status])
  @@index([isActive])
  @@map("projects")
}

enum ProjectStatus {
  ACTIVE // Em andamento
  PLANNING // Em planejamento
  SUSPENDED // Suspensa
  COMPLETED // Concluída
  CANCELLED // Cancelada
}

// Modelo de Requisição de Material
model MaterialRequest {
  id              String                  @id @default(cuid())
  requestNumber   String                  @unique // Número da requisição (ex: REQ-2025-001)
  requestedBy     String // ID do usuário que solicitou
  costCenterId    String // Centro de custo
  projectId       String? // Obra/Projeto (opcional)
  serviceOrderId  String?
  serviceOrder    String? // Ordem de serviço (texto livre)
  obra            String? // Obra (texto livre)
  description     String? // Descrição/observações da requisição
  demandSheet     String? // Número ou referência da ficha de demanda
  demandSheetAttachmentUrl  String? // URL do anexo da FD
  demandSheetAttachmentName String? // Nome original do anexo da FD
  status          MaterialRequestStatus   @default(PENDING) // Status da requisição
  /// Último tipo de entrada de estoque vinculada a OC desta RM (Total ou Parcial).
  lastStockReceiptType MaterialDeliveryReceiptType?
  priority        MaterialRequestPriority @default(MEDIUM) // Prioridade
  requestedAt     DateTime                @default(now()) // Data da requisição
  approvedBy      String? // ID do aprovador (compras)
  approvedAt      DateTime? // Data de aprovação
  rejectedBy      String? // ID de quem rejeitou
  rejectedAt      DateTime? // Data de rejeição
  rejectionReason String? // Motivo da rejeição
  completedAt     DateTime? // Data de conclusão (quando todos os itens foram atendidos)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  // Relacionamentos
  requester      User                  @relation("MaterialRequestRequester", fields: [requestedBy], references: [id], onDelete: Restrict)
  approver       User?                 @relation("MaterialRequestApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  rejecter       User?                 @relation("MaterialRequestRejecter", fields: [rejectedBy], references: [id], onDelete: SetNull)
  costCenter     CostCenter            @relation(fields: [costCenterId], references: [id], onDelete: Restrict)
  project        Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  service_orders service_orders?       @relation(fields: [serviceOrderId], references: [id])
  items          MaterialRequestItem[]
  purchaseOrders PurchaseOrder[]
  quoteMaps      QuoteMap[]            @relation("QuoteMapMaterialRequest")

  @@index([requestNumber])
  @@index([requestedBy])
  @@index([costCenterId])
  @@index([projectId])
  @@index([serviceOrderId])
  @@index([serviceOrder])
  @@index([status])
  @@index([requestedAt])
  @@map("material_requests")
}

model cacambas {
  id             String    @id
  costCenterId   String
  serviceOrderId String?
  numero         String?
  dataLocacao    DateTime?
  dataDevolucao  DateTime?
  valor          Decimal?  @db.Decimal(12, 2)
  observacao     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime

  cost_centers   CostCenter      @relation(fields: [costCenterId], references: [id], onDelete: Cascade)
  service_orders service_orders? @relation(fields: [serviceOrderId], references: [id])

  @@index([costCenterId])
  @@index([serviceOrderId])
}

model contract_additives {
  id           String   @id
  costCenterId String
  valor        Decimal  @db.Decimal(14, 2)
  descricao    String?
  dataAditivo  DateTime @default(now())
  createdAt    DateTime @default(now())

  cost_centers CostCenter @relation(fields: [costCenterId], references: [id], onDelete: Cascade)

  @@index([costCenterId])
}

model monthly_goals {
  id           String   @id
  costCenterId String
  mes          Int
  ano          Int
  meta         Decimal  @db.Decimal(14, 2)
  executado    Decimal  @default(0) @db.Decimal(14, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime

  cost_centers CostCenter @relation(fields: [costCenterId], references: [id], onDelete: Cascade)

  @@unique([costCenterId, mes, ano])
  @@index([ano, mes])
  @@index([costCenterId])
}

model service_orders {
  id            String             @id
  costCenterId  String
  numero        Int
  ano           Int
  dataInicio    DateTime
  previsaoFim   DateTime
  valor         Decimal            @db.Decimal(14, 2)
  status        ServiceOrderStatus @default(NAO_INICIADO)
  justificativa String?
  descricao     String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime

  cacambas          cacambas[]
  material_requests MaterialRequest[]
  pleitos           Pleito[]
  cost_centers      CostCenter        @relation(fields: [costCenterId], references: [id], onDelete: Cascade)

  @@unique([costCenterId, numero, ano])
  @@index([costCenterId])
  @@index([status])
}

enum MaterialRequestStatus {
  PENDING // Pendente - Aguardando análise de compras
  IN_REVIEW // Correção RM - aguardando ajuste do solicitante
  APPROVED // Aprovada - Compras aprovou e está processando
  PARTIALLY_FULFILLED // Parcialmente atendida - Alguns itens foram atendidos
  FULFILLED // Atendida - Todos os itens foram atendidos
  REJECTED // Rejeitada - Compras rejeitou a requisição
  CANCELLED // Cancelada - Engenharia cancelou a requisição
}

enum MaterialRequestPriority {
  LOW // Baixa
  MEDIUM // Média
  HIGH // Alta
  URGENT // Urgente
}

// Modelo de Item da Requisição de Material
model MaterialRequestItem {
  id                String                    @id @default(cuid())
  materialRequestId String // ID da requisição
  materialId        String // ID do material (EngineeringMaterial)
  quantity          Decimal                   @db.Decimal(10, 2) // Quantidade solicitada
  unit              String // Unidade de medida
  unitPrice         Decimal?                  @db.Decimal(12, 2) // Preço unitário no momento da requisição
  totalPrice        Decimal?                  @db.Decimal(12, 2) // Preço total (quantity * unitPrice)
  notes             String? // Observações sobre o item
  attachmentUrl     String? // URL relativa do anexo (ex.: /uploads/material-request-items/...)
  attachmentName    String? // Nome original do arquivo
  status            MaterialRequestItemStatus @default(PENDING) // Status do item
  fulfilledQuantity Decimal?                  @db.Decimal(10, 2) // Quantidade já atendida
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  // Relacionamentos
  materialRequest       MaterialRequest        @relation(fields: [materialRequestId], references: [id], onDelete: Cascade)
  material              EngineeringMaterial    @relation(fields: [materialId], references: [id], onDelete: Restrict)
  purchaseOrderItems    PurchaseOrderItem[]
  quoteMapSupplierItems QuoteMapSupplierItem[]
  quoteMapWinnerItems   QuoteMapWinnerItem[]

  @@index([materialRequestId])
  @@index([materialId])
  @@index([status])
  @@map("material_request_items")
}

enum MaterialRequestItemStatus {
  PENDING // Pendente
  APPROVED // Aprovado
  PURCHASED // Comprado
  DELIVERED // Entregue
  CANCELLED // Cancelado
}

// Modelo de Fornecedor (estilo TOTVS RM)
model Supplier {
  id                    String   @id @default(cuid())
  code                  String   @unique // Código do fornecedor
  partyType             String? // Cliente / Fornecedor
  tradeName             String? // Nome fantasia
  name                  String // Razão social / Nome
  cnpj                  String?  @unique // CPF ou CNPJ
  stateRegistration     String? // Inscrição estadual
  municipalRegistration String? // Inscrição municipal
  category              String?
  street                String?
  streetNumber          String?
  neighborhood          String?
  complement            String?
  poBox                 String? // Caixa postal
  email                 String?
  phone                 String?
  fax                   String?
  mobile                String?
  address               String? // Endereço legado / composto
  city                  String?
  state                 String? // UF
  zipCode               String?
  contactName           String? // Nome do contato
  /// Dados para remessa CNAB400 (pagamento a fornecedores) — opcionais
  bank                  String? // Nome ou identificação do banco (ex.: ITAÚ, 341)
  agency                String? // Agência do favorecido
  account               String? // Conta (sem dígito)
  accountDigit          String? // Dígito da conta
  notes                 String?
  isActive              Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchaseOrders        PurchaseOrder[]
  quoteMapSuppliers     QuoteMapSupplier[]     @relation("QuoteMapSupplierSupplier")
  quoteMapSupplierItems QuoteMapSupplierItem[] @relation("QuoteMapSupplierItemSupplier")
  quoteMapWinnerItems   QuoteMapWinnerItem[]   @relation("QuoteMapWinnerSupplier")
  materialDeliveries    MaterialDelivery[]
  logisticsDeliveryRequests LogisticsDeliveryRequest[]

  @@index([code])
  @@index([isActive])
  @@map("suppliers")
}

enum VehicleUsageType {
  FROTA
  PARTICULAR
}

/// Cadastro de veículos da frota
model Vehicle {
  id          String             @id @default(cuid())
  code        String             @unique
  marcaVeic   String?
  modeloVeic  String
  placaVeic   String             @unique
  polo        String?
  contrato    String?
  responsavel String?
  frotaPartic VehicleUsageType?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  reservations VehicleReservation[]

  @@index([code])
  @@index([placaVeic])
  @@index([isActive])
  @@map("vehicles")
}

enum VehicleReservationStatus {
  PENDING_SUPPLIES
  APPROVED
  COMPLETED
  INSPECTED
  REJECTED
  CANCELLED
}

/// Reservas de veículos da frota
model VehicleReservation {
  id                      String                   @id @default(cuid())
  code                    String                   @unique
  solicitante             String
  motorista               String
  vehicleId               String
  atividade               String
  localDestino            String
  dataUsoInicio           DateTime                 @db.Date
  dataUsoFim              DateTime                 @db.Date
  /// Ex.: ["INTEGRAL","MATUTINO"]
  periodoUso              Json                     @default("[]")
  polo                    String?
  contrato                String?
  assinatura              String
  status                  VehicleReservationStatus @default(PENDING_SUPPLIES)
  suppliesApprovedById    String?
  suppliesApprovedAt      DateTime?
  suppliesApprovalComment String?
  suppliesRejectionReason String?
  devolucaoAt             DateTime?
  baixaObservacao         String?
  baixaFotoUrl            String?
  baixaFotoKey            String?
  baixaAssinatura         String?
  baixaReportedAt         DateTime?
  baixaReportedById       String?
  vistoriaAt              DateTime?
  vistoriaLaudoUrl        String?
  vistoriaLaudoKey        String?
  vistoriaLaudoFileName   String?
  vistoriaReportedAt      DateTime?
  vistoriaReportedById    String?
  createdById             String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  vehicle            Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  createdBy          User?   @relation("VehicleReservationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  suppliesApprovedBy User?   @relation("VehicleReservationSuppliesApprover", fields: [suppliesApprovedById], references: [id], onDelete: SetNull)
  baixaReportedBy    User?   @relation("VehicleReservationBaixaReporter", fields: [baixaReportedById], references: [id], onDelete: SetNull)
  vistoriaReportedBy User?   @relation("VehicleReservationVistoriaReporter", fields: [vistoriaReportedById], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([dataUsoInicio])
  @@index([createdById])
  @@index([status])
  @@map("vehicle_reservations")
}

/// Condições de pagamento para OC (valores gravados em PurchaseOrder.paymentCondition)
model PaymentCondition {
  id            String   @id @default(cuid())
  code          String   @unique
  label         String
  paymentType   String // AVISTA | BOLETO
  /// Quantidade de parcelas (ex.: 3 boletos)
  parcelCount   Int      @default(1)
  /// Prazo em dias para cada parcela, na ordem — ex.: [30, 60, 90]
  parcelDueDays Json
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  isSystem      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([paymentType, isActive])
  @@map("payment_conditions")
}

// Modelo de Ordem de Compra (OC - estilo TOTVS RM)
model PurchaseOrder {
  id                         String              @id @default(cuid())
  orderNumber                String              @unique // Número da OC (ex: OC-2025-001)
  materialRequestId          String? // SC que originou (opcional)
  quoteMapId                 String? // Mapa de cotação que gerou esta OC (opcional)
  supplierId                 String // Fornecedor
  status                     PurchaseOrderStatus @default(PENDING)
  orderDate                  DateTime            @default(now())
  expectedDelivery           DateTime? // Data prevista de entrega
  deliveryAddress            String? // Endereço de entrega
  /// AVISTA | BOLETO
  paymentType                String?
  /// AVISTA | BOLETO_30 | BOLETO_28 (rótulos: à vista, boleto 30 dias, boleto 28 dias)
  paymentCondition           String?
  paymentDetails             String?             @db.Text // Dados do pagamento (texto livre)
  pixKeyType                 String? // Tipo de chave PIX (à vista)
  pixKey                     String? // Chave PIX (à vista)
  boletoAttachmentUrl        String? // Caminho público ex.: /uploads/purchase-orders/...
  boletoAttachmentName       String? // Nome original do arquivo
  /// Boleto para pagamento (financeiro), após OC aprovada — distinto do anexo na criação da OC
  paymentBoletoUrl           String?
  paymentBoletoName          String?
  /// Parcelas de boleto: [{ amount, dueDate, boletoUrl, boletoName }, ...] alinhado à condição de pagamento
  paymentBoletoInstallments  Json?
  /// Após anexar boleto(s), o financeiro confirma com botão para exibir a OC na fase Pagamento (comprovante/CNAB)
  paymentBoletoPhaseReleased Boolean             @default(false)
  /// Comprovante de pagamento anexado na fase Pagamento
  paymentProofUrl            String?
  paymentProofName           String?
  /// Notas fiscais anexadas após validação do comprovante: [{ url, name, uploadedAt }]
  nfAttachments              Json?
  /// Frete informado na criação (ou edição em correção). Total a pagar = soma dos itens + frete.
  freightAmount              Decimal             @default(0) @db.Decimal(15, 2)
  amountToPay                Decimal?            @db.Decimal(15, 2) // Itens + frete (recalculado ao salvar itens/frete)
  notes                      String?
  createdBy                  String // Usuário que criou
  approvedBy                 String? // Usuário que aprovou (diretoria — status APPROVED)
  approvedAt                 DateTime?
  comprasApprovedBy          String?
  comprasApprovedAt          DateTime?
  gestorApprovedBy           String?
  gestorApprovedAt           DateTime?
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt

  materialRequest MaterialRequest?    @relation(fields: [materialRequestId], references: [id], onDelete: SetNull)
  quoteMap        QuoteMap?           @relation(fields: [quoteMapId], references: [id], onDelete: SetNull)
  supplier        Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  creator         User                @relation("PurchaseOrderCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  approver        User?               @relation("PurchaseOrderApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  comprasApprover User?               @relation("PurchaseOrderComprasApprover", fields: [comprasApprovedBy], references: [id], onDelete: SetNull)
  gestorApprover  User?               @relation("PurchaseOrderGestorApprover", fields: [gestorApprovedBy], references: [id], onDelete: SetNull)
  items             PurchaseOrderItem[]
  stockShortfalls   StockShortfall[]
  materialDeliveries MaterialDelivery[]
  logisticsDeliveryRequests LogisticsDeliveryRequest[]

  @@index([orderNumber])
  @@index([materialRequestId])
  @@index([quoteMapId])
  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
  @@map("purchase_orders")
}

enum PurchaseOrderStatus {
  DRAFT // Rascunho
  PENDING_COMPRAS // OC - Aprovação Compras (0ª fase)
  PENDING // OC - Aprovação Gestor (1ª fase)
  PENDING_DIRETORIA // OC - Aprovação Diretoria (2ª fase)
  IN_REVIEW // CORREÇÃO OC - aguardando ajuste de quem criou
  APPROVED // Aprovada (após diretoria)
  PENDING_PROOF_VALIDATION // Aguardando validação do comprovante de pagamento
  PENDING_PROOF_CORRECTION // Comprovante reprovado na validação — comprador substitui e reenvia
  PENDING_NF_ATTACHMENT // Após comprovante validado — anexar NF(s)
  SENT // Enviada ao fornecedor (legado; fluxo completo atual usa FINALIZED)
  FINALIZED // Fluxo completo concluído (NF anexada — arquivo)
  PARTIALLY_RECEIVED // Parcialmente recebida
  RECEIVED // Totalmente recebida
  REJECTED // Reprovada
  CANCELLED // Cancelada
}

// Modelo de Item da Ordem de Compra
model PurchaseOrderItem {
  id                    String   @id @default(cuid())
  purchaseOrderId       String
  materialRequestItemId String? // Item da SC que originou (opcional)
  materialId            String
  quantity              Decimal  @db.Decimal(10, 2)
  unit                  String
  unitPrice             Decimal  @db.Decimal(12, 2)
  totalPrice            Decimal  @db.Decimal(12, 2)
  notes                 String?
  receivedQuantity      Decimal? @default(0) @db.Decimal(10, 2) // Quantidade já recebida
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  purchaseOrder       PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  materialRequestItem MaterialRequestItem? @relation(fields: [materialRequestItemId], references: [id], onDelete: SetNull)
  material            EngineeringMaterial  @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@index([purchaseOrderId])
  @@index([materialRequestItemId])
  @@index([materialId])
  @@map("purchase_order_items")
}

// Modelo de Mapa de Cotação (comparação de fornecedores por item)
model QuoteMap {
  id                String         @id @default(cuid())
  materialRequestId String
  createdBy         String
  status            QuoteMapStatus @default(DRAFT)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Relacionamentos
  materialRequest MaterialRequest        @relation("QuoteMapMaterialRequest", fields: [materialRequestId], references: [id], onDelete: Cascade)
  creator         User                   @relation("QuoteMapCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  purchaseOrders  PurchaseOrder[]
  suppliers       QuoteMapSupplier[]
  winners         QuoteMapWinnerItem[]
  supplierItems   QuoteMapSupplierItem[]

  @@index([materialRequestId])
  @@index([createdBy])
  @@map("quote_maps")
}

enum QuoteMapStatus {
  DRAFT // Rascunho
}

// Frete por fornecedor dentro do mapa + campos de pagamento quando for gerar OC
model QuoteMapSupplier {
  id         String   @id @default(cuid())
  quoteMapId String
  supplierId String
  freight    Decimal? @db.Decimal(12, 2)

  // Campos de pagamento (usados na geração de OC) - opcionais
  paymentType          String?
  paymentCondition     String?
  paymentDetails       String?  @db.Text
  observations         String?
  amountToPay          Decimal? @db.Decimal(15, 2)
  boletoAttachmentUrl  String?
  boletoAttachmentName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  quoteMap QuoteMap               @relation(fields: [quoteMapId], references: [id], onDelete: Cascade)
  supplier Supplier               @relation("QuoteMapSupplierSupplier", fields: [supplierId], references: [id], onDelete: Restrict)
  items    QuoteMapSupplierItem[]

  @@unique([quoteMapId, supplierId])
  @@index([quoteMapId])
  @@map("quote_map_suppliers")
}

// Preço unitário cotado por item da SC e fornecedor
model QuoteMapSupplierItem {
  id                    String  @id @default(cuid())
  quoteMapId            String
  supplierId            String
  materialRequestItemId String
  unitPrice             Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quoteMap            QuoteMap            @relation(fields: [quoteMapId], references: [id], onDelete: Cascade)
  supplier            Supplier            @relation("QuoteMapSupplierItemSupplier", fields: [supplierId], references: [id], onDelete: Restrict)
  materialRequestItem MaterialRequestItem @relation(fields: [materialRequestItemId], references: [id], onDelete: Cascade)
  quoteMapSupplier    QuoteMapSupplier    @relation(fields: [quoteMapId, supplierId], references: [quoteMapId, supplierId], onDelete: Cascade)

  @@unique([quoteMapId, supplierId, materialRequestItemId])
  @@index([quoteMapId])
  @@index([materialRequestItemId])
  @@map("quote_map_supplier_items")
}

// Vencedor calculado por item (menor (unitPrice * quantidade) + frete)
model QuoteMapWinnerItem {
  id                    String @id @default(cuid())
  quoteMapId            String
  materialRequestItemId String
  winnerSupplierId      String

  winnerScore     Decimal @db.Decimal(15, 2)
  winnerUnitPrice Decimal @db.Decimal(12, 2)
  freight         Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quoteMap            QuoteMap            @relation(fields: [quoteMapId], references: [id], onDelete: Cascade)
  materialRequestItem MaterialRequestItem @relation(fields: [materialRequestItemId], references: [id], onDelete: Cascade)
  winnerSupplier      Supplier            @relation("QuoteMapWinnerSupplier", fields: [winnerSupplierId], references: [id], onDelete: Restrict)

  @@unique([quoteMapId, materialRequestItemId])
  @@index([quoteMapId])
  @@index([winnerSupplierId])
  @@map("quote_map_winner_items")
}

// Modelo de Categoria de Material
model MaterialCategory {
  id          String   @id @default(cuid())
  code        String   @unique // Código da categoria
  name        String // Nome da categoria (ex: Materiais, Mão de Obra, Equipamentos, Serviços)
  description String? // Descrição
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamentos
  materials EngineeringMaterial[]

  @@map("material_categories")
}

// Modelo de Natureza Orçamentária
model BudgetNature {
  id        String   @id @default(cuid())
  code      String?  @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  constructionMaterials ConstructionMaterial[]

  @@index([code])
  @@index([isActive])
  @@map("budget_natures")
}

// Modelo de Material de Engenharia (SINAPI)
model EngineeringMaterial {
  id             String   @id @default(cuid())
  sinapiCode     String   @unique // Código oficial do material no SINAPI
  name           String? // Nome do material
  description    String // Descrição completa do material
  unit           String // Unidade de medida (kg, m, m², un, etc.)
  medianPrice    Decimal? @db.Decimal(12, 2) // Preço mediano atual do SINAPI
  state          String? // Estado (UF) referente ao material
  referenceMonth Int? // Mês de referência (1-12)
  referenceYear  Int? // Ano de referência
  categoryId     String? // Categoria do material
  costCenterId   String? // Centro de custo associado
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relacionamentos
  category           MaterialCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  costCenter         CostCenter?           @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  priceHistory       PriceHistory[]
  requestItems       MaterialRequestItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([sinapiCode])
  @@index([state])
  @@index([categoryId])
  @@index([costCenterId])
  @@index([isActive])
  @@map("engineering_materials")
}

// Modelo de Composição SINAPI (CPU - Composição de Preços Unitários)
model Composition {
  id             String   @id @default(cuid())
  sinapiCode     String // Código oficial da composição no SINAPI
  description    String // Descrição da composição
  unit           String // Unidade de medida (m², m³, etc.)
  compositePrice Decimal? @db.Decimal(12, 2) // Custo total (materiais + mão de obra + equipamentos)
  state          String? // Estado (UF) referente
  referenceMonth Int? // Mês de referência (1-12)
  referenceYear  Int? // Ano de referência
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relacionamentos
  priceHistory PriceHistory[]

  @@index([sinapiCode])
  @@index([state])
  @@index([isActive])
  @@map("compositions")
}

// Modelo de Histórico de Preços
model PriceHistory {
  id            String   @id @default(cuid())
  materialId    String? // ID do material (se aplicável)
  compositionId String? // ID da composição (se aplicável)
  price         Decimal  @db.Decimal(12, 2) // Valor registrado
  referenceDate DateTime // Data de referência (mês/ano)
  source        String   @default("SINAPI") // Fonte (SINAPI, ou outro sistema)
  createdAt     DateTime @default(now())

  // Relacionamentos
  material    EngineeringMaterial? @relation(fields: [materialId], references: [id], onDelete: Cascade)
  composition Composition?         @relation(fields: [compositionId], references: [id], onDelete: Cascade)

  @@index([materialId])
  @@index([compositionId])
  @@index([referenceDate])
  @@map("price_history")
}

// Modelo de Material de Construção Civil
model ConstructionMaterial {
  id               String   @id @default(cuid())
  code             String? // Código do produto
  name             String // Nome do produto
  productType      String? // Tipo do produto
  description      String? // Descrição do produto
  category         String? // Legado (categoria antiga)
  dimensions       String? // Dimensões do material
  productImageUrl  String? // URL da imagem do produto
  productImageName String? // Nome original do arquivo da imagem
  unit             String // Unidade de medida (kg, m, m², un, etc.)
  budgetNatureId   String?
  budgetNature     BudgetNature? @relation(fields: [budgetNatureId], references: [id], onDelete: SetNull)
  isActive         Boolean  @default(true) // Se está ativo
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  stockMovements  StockMovement[]
  stockShortfalls StockShortfall[]

  @@index([code])
  @@index([name])
  @@index([budgetNatureId])
  @@index([isActive])
  @@map("construction_materials")
}

enum StockShortfallStatus {
  ABERTO
  RESOLVIDO
}

/// Pendência de entrega (furo) após recebimento parcial na OC — material ainda não totalmente recebido.
model StockShortfall {
  id                     String               @id @default(cuid())
  purchaseOrderId        String
  purchaseOrder          PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  orderNumber            String
  costCenterId           String?
  costCenter             CostCenter?          @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  constructionMaterialId String
  constructionMaterial   ConstructionMaterial @relation(fields: [constructionMaterialId], references: [id], onDelete: Cascade)
  engineeringLabel       String               @db.Text
  unit                   String?
  orderedQty             Decimal              @db.Decimal(12, 2)
  receivedQty            Decimal              @db.Decimal(12, 2)
  gapQty                 Decimal              @db.Decimal(12, 2)
  status                 StockShortfallStatus @default(ABERTO)
  resolvedAt             DateTime?
  resolvedByUserId       String?
  resolvedBy             User?                @relation("StockShortfallResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@unique([purchaseOrderId, constructionMaterialId])
  @@index([orderNumber])
  @@index([status])
  @@index([costCenterId])
  @@map("stock_shortfalls")
}

// Modelo de Movimentação de Estoque
model StockMovement {
  id           String               @id @default(cuid())
  materialId   String
  material     ConstructionMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  costCenterId String?
  costCenter   CostCenter?          @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  type         String // 'IN' (entrada) ou 'OUT' (saída)
  quantity     Float
  notes        String? // Observações sobre a movimentação
  userId       String // Usuário que realizou a movimentação
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime             @default(now())
  materialDelivery MaterialDelivery?

  @@index([materialId])
  @@index([costCenterId])
  @@index([type])
  @@index([createdAt])
  @@map("stock_movements")
}

// Modelo de Conversas com ChatGPT
model ChatGPTConversation {
  id        String   @id @default(cuid())
  userId    String // Usuário que criou a conversa
  title     String // Título da conversa (primeira mensagem)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatGPTMessage[]

  @@index([userId])
  @@index([createdAt])
  @@map("chatgpt_conversations")
}

// Modelo de Mensagens do ChatGPT
model ChatGPTMessage {
  id             String   @id @default(cuid())
  conversationId String // Conversa à qual pertence
  role           String // 'user' ou 'assistant'
  content        String // Conteúdo da mensagem
  createdAt      DateTime @default(now())

  // Relacionamento
  conversation ChatGPTConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("chatgpt_messages")
}

// Modelo para tokens de reset de senha
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relacionamentos
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model UserPermission {
  id        String   @id @default(cuid())
  userId    String
  module    String
  action    String
  allowed   Boolean  @default(true)
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User  @relation("UserPermissionUser", fields: [userId], references: [id], onDelete: Cascade)
  updater User? @relation("UserPermissionUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@unique([userId, module, action])
  @@index([userId])
  @@index([module, action])
  @@map("user_permissions")
}

/// Contratos que um usuário não-admin pode acessar (além da permissão de módulo "Contratos").
model UserContractPermission {
  id         String   @id @default(cuid())
