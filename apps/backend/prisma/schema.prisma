// Espelho NF — Código Tributário
model EspelhoNfTaxCode {
  id                   String   @id @default(cuid())
  name                 String // Nome exibido no frontend (antes "cityName")
  abatesMaterial       Boolean  @default(false)
  /// Possui garantia complementar (contrato)
  hasComplementaryWarranty Boolean @default(false)
  /// Se possui garantia: a garantia é retida na nota? (null = não se aplica)
  garantiaRetidaNaNota Boolean?
  /// Alíquota da garantia (%), texto pt-BR; vazio se não houver garantia complementar
  garantiaAliquota     String   @default("")
  issRate              String
  cofinsCollectionType String   @default("RETIDO")
  csllCollectionType   String   @default("RETIDO")
  inssCollectionType   String   @default("RETIDO")
  irpjCollectionType   String   @default("RETIDO")
  pisCollectionType    String   @default("RETIDO")
  issCollectionType    String   @default("RETIDO")
  inssMaterialLimit    String
  issMaterialLimit     String
  /// Alíquotas federais (COFINS, CSLL, etc.) por tipo de contrato — espelhado na UI de cadastro.
  federalRatesByContext    Json?
  /// Qual linha de contrato federal está ativa na UI (checkboxes por contexto).
  federalTaxContextEnabled Json?
