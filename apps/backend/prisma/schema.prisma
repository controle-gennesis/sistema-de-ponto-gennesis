/// Status da OS no Controle Financeiro (planilha "CONTROLE FINANCEIRO - MATERIAL/SERVIÇO APLICADO")
enum FinancialControlStatus {
  PROCESSO_COMPLETO // CONCLUÍDO (verde)
  PAGO              // PAGO (verde claro)
  AGUARDAR_NOTA     // PENDENTE (amarelo)
  CANCELADO         // CANCELADO (vermelho)
}

/// Lançamentos da página "Controle Financeiro" (Material/Serviço Aplicado).
/// Cada linha representa uma OS e suas informações de pagamento.
model FinancialControlEntry {
  id              String                  @id @default(cuid())
  /// Mês e ano de referência do pagamento (para agrupamento na UI: JANEIRO/2025, FEVEREIRO/2025...).
  paymentMonth    Int // 1-12
  paymentYear     Int
  /// Status visual da linha (cor da primeira coluna).
  status          FinancialControlStatus @default(AGUARDAR_NOTA)
  /// "O.S." — código ou identificação da Ordem de Serviço (ex.: ADM, IMP-20/SC-01, AD-11/SC-02).
  osCode          String?
  /// "Código-Nome do Fornecedor".
  supplierName    String?
  /// "Prf-Numero Parcela" (ex.: 3167883, 000391-1, 000010-1/2).
  parcelNumber    String?
  /// "Data de Emissão" da nota/título.
  emissionDate    DateTime?
  /// "Boleto" — Sim/Não/CANCELADA (texto livre para refletir a planilha).
  boleto          String?
  /// "Data de Vencto" — vencimento do pagamento.
  dueDate         DateTime?
  /// "Valor Original" do título.
  originalValue   Decimal?               @db.Decimal(15, 2)
  /// "O. C." — Ordem de Compra ou número auxiliar.
  ocNumber        String?
  /// "Valor Final" (após acertos/encontro de contas).
  finalValue      Decimal?               @db.Decimal(15, 2)
  /// "PAGO DIA" — data em que o pagamento foi efetivamente realizado.
  paidDate        DateTime?
  /// "Falta Dias" — campo numérico calculado/manual na planilha.
  remainingDays   Int?
  /// "Recebido" — observação livre (ex.: PAGO TED, PAGO PIX, CANCELADO, PAGO pelo ÊNFASE).
  receivedNote    String?
  notes           String?

  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  createdBy       String?
  updatedBy       String?

  @@index([paymentYear, paymentMonth])
  @@index([status])
  @@index([dueDate])
  @@index([supplierName])
  @@map("financial_control_entries")
}

/// Ajustes manuais permanentes no extrato de caixa (correções fora do TOTVS RM).
model ExtratoCaixaAjuste {
  id               String    @id @default(cuid())
  dataCompensacao  DateTime  @db.Date
  codCCusto        String    @default("")
  ccusto           String    @default("")
  codNatFinanceira String    @default("")
  natureza         String    @default("")
  codFilial        Int?
  fornecedor       String    @default("")
  valor            Decimal   @db.Decimal(18, 2)
  observacao       String?
  createdById      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([dataCompensacao])
  @@index([codFilial])
  @@map("extrato_caixa_ajustes")
}

/// Presets de filtro do extrato de caixa (por usuário).
model ExtratoCaixaFiltroSalvo {
  id        String   @id @default(cuid())
  userId    String
  nome      String
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, nome])
  @@index([userId])
  @@map("extrato_caixa_filtros_salvos")
}

// ─── Tasks (Kanban) ───────────────────────────────────────────────────────────

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum KanbanBoardSharePermission {
  READ
  WRITE
}

model KanbanBoard {
  id              String   @id @default(cuid())
  name            String   @default("Tasks")
  slug            String   @unique
  departmentKey   String   @unique @map("department_key")
  departmentLabel String   @map("department_label")
  /// Quadro criado manualmente (não vinculado ao setor do funcionário).
  isCustom        Boolean  @default(false) @map("is_custom")
  /// Paleta de etiquetas do setor: [{ color, name }]
  labelPresets    Json     @default("[]") @map("label_presets")
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  columns KanbanColumn[]
  shares  KanbanBoardShare[]
  creator User? @relation("KanbanBoardCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isCustom])
  @@index([createdById])
  @@map("kanban_boards")
}

/// Quem tem acesso a quadros personalizados (além do criador).
model KanbanBoardShare {
  id         String                     @id @default(cuid())
  boardId    String                     @map("board_id")
  userId     String                     @map("user_id")
  permission KanbanBoardSharePermission @default(WRITE)
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt
  createdBy  String?                    @map("created_by")

  board   KanbanBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user    User        @relation("KanbanBoardShareUser", fields: [userId], references: [id], onDelete: Cascade)
  creator User?       @relation("KanbanBoardShareCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([boardId, userId])
  @@index([userId])
  @@index([boardId])
  @@map("kanban_board_shares")
}

model KanbanColumn {
  id        String   @id @default(cuid())
  boardId   String
  title     String
  color     String   @default("#6B7280")
  position  Int      @default(0)
  cardLimit Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board KanbanBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards KanbanCard[]

  @@index([boardId])
  @@map("kanban_columns")
}

model KanbanCard {
  id             String       @id @default(cuid())
  columnId       String
  title          String
  description    String       @default("")
  priority       TaskPriority @default(MEDIUM)
  startDate      DateTime?
  endDate        DateTime?    @map("dueDate")
  assigneeUserId String?
  assigneeName   String?
  totalTasks        Int          @default(0)
  completedTasks    Int          @default(0)
  checklistEnabled    Boolean      @default(false)
  attachmentsEnabled  Boolean      @default(false)
  labels              Json         @default("[]")
  position       Int          @default(0)
  completedAt    DateTime?
  workHours      Decimal?     @db.Decimal(8, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  column         KanbanColumn          @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assignee       User?                 @relation("KanbanCardAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  members        KanbanCardMember[]
  checklistItems KanbanChecklistItem[]
  comments       KanbanCardComment[]
  attachments    KanbanCardAttachment[]

  @@index([columnId])
  @@index([assigneeUserId])
  @@map("kanban_cards")
