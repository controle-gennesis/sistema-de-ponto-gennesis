  position       Int       @default(0)
  assigneeUserId String?
  dueDate        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  card     KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  assignee User?      @relation("KanbanChecklistAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)

  @@index([cardId])
  @@index([assigneeUserId])
  @@map("kanban_checklist_items")
}

model KanbanCardComment {
  id        String   @id @default(cuid())
  cardId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  card   KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author User       @relation("KanbanCardCommentAuthor", fields: [userId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([userId])
  @@map("kanban_card_comments")
}

model KanbanCardAttachment {
  id        String   @id @default(cuid())
  cardId    String
  userId    String
  fileName  String
  fileUrl   String
  fileKey   String?
  fileSize  Int      @default(0)
  mimeType  String   @default("application/octet-stream")
  createdAt DateTime @default(now())

  card     KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  uploader User       @relation("KanbanCardAttachmentUploader", fields: [userId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([userId])
  @@map("kanban_card_attachments")
}

/// Controle de entregas de material (substitui planilha de recebimento)
enum MaterialDeliveryReceiptType {
  TOTAL
  PARCIAL
}

model MaterialDelivery {
  id                  String                          @id @default(cuid())
  deliveryNumber      String                          @unique
  polo                MaterialDeliveryPolo
  stockMovementId     String?                         @unique
  receiptType         MaterialDeliveryReceiptType?
  movementId          String?
  movementNumber      String?
  contractId          String?
  currentStatus       MaterialDeliveryCurrentStatus   @default(APROVADO_SUPRIMENTOS)
  paymentStatus       MaterialDeliveryPaymentStatus   @default(AGUARDANDO_PAGAMENTO)
  supplierId          String?
  supplierName        String?
  purchaseOrderId     String?
  orderValue          Decimal?                        @db.Decimal(15, 2)
  expectedDelivery    DateTime?
  actualDelivery      DateTime?
  totalPaid           Decimal?                        @db.Decimal(15, 2)
  stockShortfallType  MaterialDeliveryStockShortfallType?
  rmNumber            String?
  deliveryType        String?
  observations        String?                         @db.Text
  finalStatus         MaterialDeliveryFinalStatus     @default(PENDENTE)
  receivedByEngineering Boolean                       @default(false)
  receivedByUserId    String?
  receivedAt          DateTime?
  createdBy           String
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @updatedAt

  supplier      Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  contractRecord Contract?     @relation(fields: [contractId], references: [id], onDelete: SetNull)
  creator       User           @relation("MaterialDeliveryCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  receivedByUser User?         @relation("MaterialDeliveryReceiver", fields: [receivedByUserId], references: [id], onDelete: SetNull)
  stockMovement StockMovement?  @relation(fields: [stockMovementId], references: [id], onDelete: SetNull)

  @@index([polo])
  @@index([stockMovementId])
  @@index([receiptType])
  @@index([currentStatus])
  @@index([paymentStatus])
  @@index([finalStatus])
  @@index([receivedByEngineering])
  @@index([expectedDelivery])
  @@index([supplierId])
  @@index([purchaseOrderId])
  @@index([contractId])
  @@map("material_deliveries")
}

enum MaterialDeliveryStockShortfallType {
  NORMAL
  CORRECAO
}

enum MaterialDeliveryPolo {
  DF
  GO
}

enum MaterialDeliveryCurrentStatus {
  ENTREGA_FORNECEDOR_CIF
  APROVADO_SUPRIMENTOS
  ENTREGA_LOGISTICA_FOB
  ENTREGUE
  APROVAR_DIR
  CANCELADO
}

enum MaterialDeliveryPaymentStatus {
  OK
  AGUARDANDO_PAGAMENTO
  BOLETO
  A_VISTA
  CANCELADO
  CREDITO
}

enum MaterialDeliveryFinalStatus {
  PENDENTE
  CONCLUIDO
  CANCELADO
}

/// Espelho da aba GERAL (coluna E → L): ID Mov → Normal/Correção para pagamento boleto
model MaterialDeliveryGeralLookup {
  id             String                          @id @default(cuid())
  lookupKey      String                          @unique
  shortfallType  MaterialDeliveryStockShortfallType
  createdAt      DateTime                        @default(now())
  updatedAt      DateTime                        @updatedAt

  @@index([lookupKey])
  @@map("material_delivery_geral_lookups")
}

enum FuelVehicleType {
  PRIVATE
  COMPANY
}

enum FuelTankLevelAfter {
  RESERVE
  QUARTER
  HALF
  THREE_QUARTERS
  FULL
}

enum FuelRefuelRequestStatus {
  PENDING_MANAGER
  PENDING_SUPPLIES
  AWAITING_REFUEL
  COMPLETED
  APPROVED
  REJECTED
  CANCELLED
}

/// Sessão de fluxo conversacional da Gennecy (ex.: solicitação de abastecimento).
model GennecyChatFlowSession {
  id        String   @id @default(cuid())
  chatId    String
  userId    String
  flowType  String
  step      String
  payload   Json     @default("{}")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chatId, userId, flowType])
  @@index([chatId])
  @@index([userId])
  @@map("gennecy_chat_flow_sessions")
}

/// Solicitação de abastecimento de combustível (espelho do AppSheet tb solicitAbast).
model FuelRefuelRequest {
  id            String @id @default(cuid())
  displayNumber Int    @unique

  requesterId String
  requester   User   @relation("FuelRefuelRequester", fields: [requesterId], references: [id], onDelete: Restrict)

  requestedAt DateTime @default(now())
  refuelDate  DateTime
  route       String
  costCenter  String?
  contractId  String?
  contract    Contract? @relation(fields: [contractId], references: [id], onDelete: Restrict)

  driverName         String
  vehiclePlate       String
  vehicleDescription String?
  /// Particular → aprovação do gestor; frota/empresa → fila direta do Suprimentos.
  vehicleType        FuelVehicleType?

  dashboardPhotoUrl  String?
  dashboardPhotoKey  String?
  dashboardPhotoName String?

  observations String?
  status       FuelRefuelRequestStatus @default(PENDING_MANAGER)
  sourceChatId String?
  sourceWhatsAppPhone String?

  managerApprovedBy      String?
  managerApprovedAt      DateTime?
  managerApprovalComment String?
  managerRejectionReason String?

  suppliesApprovedBy      String?
  suppliesApprovedAt      DateTime?
  suppliesApprovalComment String?
  suppliesRejectionReason String?

  refuelReportedAt        DateTime?
  odometerKm              Int?
  tankLevelAfter          FuelTankLevelAfter?
  refuelReportObservations String?
  receiptPhotoUrl         String?
  receiptPhotoKey         String?
  receiptPhotoName        String?
  litersRefueled          Decimal? @db.Decimal(10, 3)
  pricePerLiter           Decimal? @db.Decimal(10, 2)

  managerApprover User? @relation("FuelRefuelManager", fields: [managerApprovedBy], references: [id], onDelete: SetNull)
  suppliesApprover User? @relation("FuelRefuelSupplies", fields: [suppliesApprovedBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requesterId])
  @@index([contractId])
  @@index([status])
  @@index([refuelDate])
  @@map("fuel_refuel_requests")
}

enum LogisticsDeliveryUrgency {
  NORMAL
  URGENT
}

enum LogisticsDeliveryRequestStatus {
  PENDING
  COMPLETED
}

enum LogisticsDeliveryOutcome {
  DELIVERED
  PARTIAL
  NOT_DELIVERED
}

/// Solicitação de entrega logística (tb solicitação logística).
model LogisticsDeliveryRequest {
  id            String @id @default(cuid())
  displayNumber Int    @unique

  status LogisticsDeliveryRequestStatus @default(PENDING)

  requestedAt DateTime
  urgency     LogisticsDeliveryUrgency @default(NORMAL)

  contractId String?
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id], onDelete: SetNull)

  serviceOrderId     String?
  serviceOrderNumber String?

  purchaseOrderId     String?
  purchaseOrderNumber String?
  purchaseOrder       PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  movementId String

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  driverName String?

  materialId   String?
  materialName String?

  materialAttachmentUrl  String?
  materialAttachmentName String?

  value            Decimal  @db.Decimal(15, 2)
  history          String?  @db.Text
  observations     String?  @db.Text
  expectedDelivery DateTime?

  createdBy String
  creator   User   @relation("LogisticsDeliveryCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  completion LogisticsDeliveryCompletion?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdBy])
  @@index([status])
  @@index([contractId])
  @@index([costCenterId])
  @@index([purchaseOrderId])
  @@index([supplierId])
  @@index([requestedAt])
  @@map("logistics_delivery_requests")
}

/// Feedback de entrega logística (tb feedback entrega fornecedor log).
model LogisticsDeliveryCompletion {
  id                String @id @default(cuid())
  deliveryRequestId String @unique
  deliveryRequest   LogisticsDeliveryRequest @relation(fields: [deliveryRequestId], references: [id], onDelete: Cascade)

  receivingLocation    String
  receivingResponsible String
  receivedAt           DateTime
  deliveryOutcome      LogisticsDeliveryOutcome

  locationPhotoUrl String
  locationPhotoKey String?
  observations     String? @db.Text

  completedBy String
  completer   User   @relation("LogisticsDeliveryCompleter", fields: [completedBy], references: [id], onDelete: Restrict)

  invoiceAttachments LogisticsDeliveryInvoiceAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([completedBy])
  @@index([receivedAt])
  @@map("logistics_delivery_completions")
}

/// Notas fiscais anexadas na finalização (tb nf feedback log).
model LogisticsDeliveryInvoiceAttachment {
  id             String @id @default(cuid())
  completionId   String
  completion     LogisticsDeliveryCompletion @relation(fields: [completionId], references: [id], onDelete: Cascade)
  attachmentUrl  String
  attachmentName String?

  createdAt DateTime @default(now())

  @@index([completionId])
  @@map("logistics_delivery_invoice_attachments")
}
