  bankAccount EspelhoNfBankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  mirrors    EspelhoNfMirror[]

  @@index([costCenterId])
  @@index([taxCodeId])
  @@index([bankAccountId])
  @@index([corporateName])
  @@index([cnpj])
  @@map("espelho_nf_service_takers")
}

// Espelho NF — Conta Bancária
model EspelhoNfBankAccount {
