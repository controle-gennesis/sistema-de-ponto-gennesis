{
  "name": "sistema-ponto-engenharia",
  "version": "1.0.0",
  "description": "Sistema completo de controle de ponto para empresa de engenharia",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd apps/backend && npm run dev",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:permission-modules": "npm run build -w @sistema-ponto/permission-modules",
    "build:backend": "npm run build:permission-modules && cd apps/backend && npm run db:generate && npm run build",
    "build:frontend": "cd apps/frontend && npm run build",
    "start": "npm run start:backend",
    "start:backend": "cd apps/backend && npm run start",
    "install:all": "npm install && npm run install:backend && npm run install:frontend",
    "install:backend": "cd apps/backend && npm install",
    "install:frontend": "cd apps/frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "react-calendar": "^6.0.0"
  },
  "overrides": {
    "minimatch": "^9.0.7",
    "glob": "^10.5.0",
    "qs": "^6.14.2",
    "picomatch": "^2.3.2"
  }
}
